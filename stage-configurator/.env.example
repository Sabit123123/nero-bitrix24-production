# Supabase (optional — without these, projects save to localStorage)
# Get from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key — required for server-side model uploads (SKP/GLB import)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# CloudConvert (required for SKP/OBJ/FBX/DAE conversion)
# Free tier: 25 conversions/day — https://cloudconvert.com
CLOUDCONVERT_API_KEY=eyJ...

# App URL (for canonical links in PDF export)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
