# AquaUzel — пример переменных для подключения Supabase.
# Эти значения ПУБЛИЧНЫЕ (предназначены для клиента); вписываются в
# assets/js/supabase-config.js. Доступ к данным ограничивают политики RLS.
#
# Пароль администратора здесь НЕ хранится — администратор создаётся в
# Supabase → Authentication → Users, и пароль проверяет Supabase Auth.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key...
SUPABASE_BUCKET=product-images
